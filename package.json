{
    "name": "@plotnerd/stat-engine",
    "version": "2.0.0",
    "description": "Multi-algorithm quartile & statistics engine — Tukey, R-7, Excel QUARTILE.INC/EXC, WolframAlpha. Powers plotnerd.com.",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "tsc --noEmit",
        "docs": "typedoc",
        "prepublishOnly": "npm test && npm run build"
    },
    "keywords": [
        "statistics",
        "quartile",
        "quartiles",
        "percentile",
        "box-plot",
        "boxplot",
        "five-number-summary",
        "IQR",
        "interquartile-range",
        "outlier-detection",
        "tukey",
        "tukey-hinges",
        "r-7",
        "excel",
        "wolfram-alpha",
        "data-science",
        "math",
        "plotnerd"
    ],
    "author": "PlotNerd Team",
    "license": "MIT",
    "homepage": "https://plotnerd.com",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/paradoxie/stat-engine.git"
    },
    "bugs": {
        "url": "https://github.com/paradoxie/stat-engine/issues"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^1.6.1",
        "tsup": "^8.0.0",
        "typedoc": "^0.28.17",
        "typescript": "^5.9.0",
        "vitest": "^1.3.0"
    },
    "engines": {
        "node": ">=18"
    }
}